# ─────────────────────────────────────────────
#  Catadores Digitais — .gitignore
#  Cobre: Node/Vite/React, Firebase, variáveis
#  de ambiente, editores, sistema operacional.
# ─────────────────────────────────────────────


# ── Variáveis de ambiente (NUNCA subir) ───────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.env.*.local
*.env


# ── Firebase ──────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
database-debug.log
# Chaves de serviço e credenciais
*service-account*.json
*serviceAccount*.json
*firebase-adminsdk*.json
google-services.json
GoogleService-Info.plist


# ── Node.js ───────────────────────────────────
node_modules/
.npm
.yarn/
.pnp
.pnp.js
.yarn-integrity


# ── Build outputs ─────────────────────────────
dist/
dist-ssr/
build/
out/
.output/
.vercel/
.netlify/


# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Cache e temporários ───────────────────────
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache
.temp/
tmp/
temp/


# ── Testes ────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/


# ── Claude Code ───────────────────────────────
# Manter: .claude/settings.json (configurações compartilháveis do projeto)
# Ignorar: configurações locais da máquina
.claude/settings.local.json


# ── macOS ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon$


# ── Windows ───────────────────────────────────
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk


# ── Linux ─────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ── Editores ──────────────────────────────────
# VS Code — manter extensions.json e settings.json se forem do projeto
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ…)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.#*

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Cursor
.cursor/


# ── Misc sensível ─────────────────────────────
# Certificados e chaves
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks

# Secrets genéricos — evitar acidentes
secrets.json
secrets.yaml
secrets.yml
config/secrets.*
